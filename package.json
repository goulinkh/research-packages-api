{
  "name": "research-packages-api",
  "version": "0.1.0",
  "private": false,
  "description": "Typed TypeScript client for the Launchpad web-service API (api.launchpad.net), generated from the published OpenAPI 3.0 spec.",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "engines": {
    "node": ">=22.6"
  },
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "openapi:update": "npm run openapi:update-schema && npm run openapi:generate-types",
    "openapi:update-schema": "./scripts/openapi-update-schema.sh",
    "openapi:generate-types": "openapi-typescript .api-spec/launchpad-devel.yaml -o src/schema/devel.ts --root-types --root-types-no-schema-prefix --enum-values",
    "typecheck": "tsc --noEmit",
    "example": "node --experimental-strip-types examples/list-distributions.ts"
  },
  "dependencies": {
    "openapi-fetch": "^0.17.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "openapi-typescript": "^7.13.0",
    "openapi-typescript-helpers": "^0.1.0",
    "typescript": "^5.7.3"
  }
}
